# ─────────────────────────────────────────────────────────────────────────────
# Production env for docker-compose.prod.yml.
# On the EC2 box:  cp .env.prod.example .env.prod && chmod 600 .env.prod
# Then fill in REAL values. NEVER commit a filled-in .env.prod.
# ─────────────────────────────────────────────────────────────────────────────

# --- Domain / TLS ---
DOMAIN=authzy.duckdns.org             # DuckDNS subdomain → must point at the EC2 Elastic IP
ACME_EMAIL=miskintanushree@gmail.com  # Let's Encrypt registration + expiry notices

# --- Postgres (runs as a container on this box) ---
DB_USER=rbac_app
DB_PASSWORD=replace-with-a-strong-password    # openssl rand -base64 24
DB_NAME=rbac_db

# --- MongoDB Atlas ---
# Whitelist this EC2 instance's Elastic IP in Atlas → Network Access first.
MONGO_URI=mongodb+srv://USER:PASS@cluster.xxxx.mongodb.net/dbname?retryWrites=true&w=majority

# --- Auth ---
JWT_SECRET=replace-with-a-long-random-secret  # openssl rand -hex 32

# --- SMTP (Brevo example; SMTP_FROM must be a verified sender) ---
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=replace-with-provider-login
SMTP_PASS=replace-with-provider-smtp-key
SMTP_FROM="Config Service <your-verified-email@example.com>"

# --- Frontend build-time public vars (inlined into the bundle at build) ---
# API base is derived automatically as https://${DOMAIN}/api in the compose file.
NEXT_PUBLIC_CONTEXT_ID=               # context UUID (optional; used for x-context-id)
NEXT_PUBLIC_CLIENT_ID=                # optional; client_id is normally resolved from hostname

# --- Backups (used by deploy/backup-postgres.sh; optional) ---
BACKUP_S3_BUCKET=                     # e.g. s3://my-rbac-backups (empty = local-only)
